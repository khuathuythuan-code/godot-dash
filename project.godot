[input_devices]

pointing/android/enable_pan_and_scale_gestures=true

[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="solids"
2d_physics/layer_3="rectangular_hazards"
2d_physics/layer_4="interactables"
2d_physics/layer_5="triggers"
2d_physics/layer_6="ground"
2d_physics/layer_7="slope_enablers"
2d_physics/layer_8="editor"
2d_physics/layer_9="editor_selection_colliders"
2d_physics/layer_10="solid_overlap_check"
2d_physics/layer_11="velocity_redirectors"
2d_physics/layer_12="circular_hazards"

[phantom_camera]

updater/enable_updater=false
updater/show_new_release_info_on_editor_launch_in_output=false

[physics]

common/physics_ticks_per_second=240
common/physics_interpolation=true

[plugin]

script-ide/functions=false
script-ide/engine_callbacks=false
script-ide/signals=false
script-ide/exported_properties=false
script-ide/properties=false
script-ide/classes=false
script-ide/constants=false

[rendering]

textures/canvas_textures/default_texture_filter=2
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
viewport/hdr_2d=true
anti_aliasing/screen_space_roughness_limiter/enabled=false

[shader_globals]

menu_blur={
"type": "bool",
"value": true
}
blur_strength={
"type": "float",
"value": 3.0
}
ui_color={
"type": "color",
"value": Color(0.5019608, 0.5019608, 0.5019608, 1)
}
