; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

instance_dock/scenes=[{
"name": "Solids",
"scenes": [{
"scene": "res://scenes/components/level_components/solids/DefaultCube.tscn"
}],
"scroll": 0
}, {
"name": "Hazards",
"scenes": [{
"scene": "res://scenes/components/level_components/hazards/Spike.tscn"
}],
"scroll": 0
}, {
"name": "Gamemode Portals",
"scenes": [{
"scene": "res://scenes/components/level_components/portals/gamemode_portals/ShipPortal.tscn"
}, {
"scene": "res://scenes/components/level_components/portals/gamemode_portals/SwingPortal.tscn"
}, {
"scene": "res://scenes/components/level_components/portals/gamemode_portals/UFOPortal.tscn"
}],
"scroll": 0
}, {
"name": "Speed Portals",
"scenes": [],
"scroll": 0
}, {
"name": "Other Portals",
"scenes": [],
"scroll": 0
}]
instance_dock/preview_resolution=Vector2i(64, 64)

[animation]

warnings/check_invalid_track_paths=false

[application]

config/name="godot-dash"
config/version="0.0.1"
run/main_scene="res://scenes/TitleScreen.tscn"
config/use_custom_user_dir=true
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
boot_splash/image="uid://c1mj3e3vvh1h0"
config/icon="uid://c8auew2txgxb5"

[audio]

buses/default_bus_layout="uid://htget5gliwyv"

[autoload]

LevelManager="*res://src/autoloads/LevelManager.gd"
SFXManager="*res://src/autoloads/SFXManager.gd"
GroundData="*res://src/autoloads/GroundData.gd"
MusicVolume="*res://src/autoloads/MusicVolume.gd"
Config="*res://src/autoloads/Config.gd"
Toasts="*res://src/autoloads/Toasts.gd"
SceneManager="*res://src/autoloads/SceneManager.gd"
Files="*res://scenes/autoloads/Files.tscn"
AssetManager="*res://src/autoloads/AssetManager.gd"
Editor="*res://src/autoloads/Editor.gd"
KeymapLoader="*res://src/autoloads/KeymapLoader.gd"
DebugMenu="*uid://cggqb75a8w8r"
DiscordRPCManager="*res://src/autoloads/DiscordRPCManager.gd"
SignalLens="*uid://85rkx60vm7a7"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
display_server/driver.linuxbsd="wayland"

[dotnet]

project/assembly_name="godot-dash"

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/ReorderableContainer/plugin.cfg", "res://addons/SmoothScroll/plugin.cfg", "res://addons/StyleboxFancy/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/discord-rpc-gd/plugin.cfg", "res://addons/nine_patch_sprite_2d/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/script-ide/plugin.cfg", "res://addons/search_bar_node/plugin.cfg", "res://addons/signal_lens/plugin.cfg", "res://addons/stopwatch/plugin.cfg", "res://addons/trail_2d/plugin.cfg")

[filesystem]

import/blender/enabled=false

[gui]

theme/custom="uid://cntfsyilhn2ic"

