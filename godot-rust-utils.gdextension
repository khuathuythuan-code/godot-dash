[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://rust/bin/debug/linux/libgodot_rust_utils.so"
linux.release.x86_64 =   "res://rust/bin/release/linux/libgodot_rust_utils.so"

windows.debug.x86_64 =   "res://rust/bin/debug/windows/godot_rust_utils.dll"
windows.release.x86_64 = "res://rust/bin/release/windows/godot_rust_utils.dll"

android.debug.arm64 =  "res://rust/bin/debug/android/libgodot_rust_utils.so"
android.release.arm64 =  "res://rust/bin/release/android/libgodot_rust_utils.so"
